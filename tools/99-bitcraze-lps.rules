# Loco Positioning Node CDC ACM (Normal mode)
SUBSYSTEM=="tty", ATTRS{idVendor}=="0483", ATTRS{idProduct}=="5740", SYMLINK+="loco_node", MODE="0666", ENV{ID_MM_DEVICE_IGNORE}="1"

# Loco Positioning Node DFU Bootloader
SUBSYSTEM=="usb", ATTRS{idVendor}=="0483", ATTRS{idProduct}=="df11", MODE="0664", GROUP="plugdev"
